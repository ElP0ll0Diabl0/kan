{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.16/MicrosoftTeams.schema.json",
  "manifestVersion": "1.16",
  "version": "1.0.0",
  "id": "${{MICROSOFT_BOT_ID}}",
  "packageName": "bn.kan.bot",
  "developer": {
    "name": "Kan",
    "websiteUrl": "https://kan.bn",
    "privacyUrl": "https://kan.bn/privacy",
    "termsOfUseUrl": "https://kan.bn/terms"
  },
  "name": {
    "short": "Kan",
    "full": "Kan — the open source Trello alternative"
  },
  "description": {
    "short": "Get your Kan notifications in Teams.",
    "full": "Receive your Kan card and workspace notifications directly in Microsoft Teams. Sign in to Kan with your Microsoft account, then message the Kan bot to connect."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#282828",
  "bots": [
    {
      "botId": "${{MICROSOFT_BOT_ID}}",
      "scopes": ["personal"],
      "supportsFiles": false,
      "isNotificationOnly": false
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["${{KAN_DOMAIN}}"]
}
